# ============================================
# Power Platform Dev Agency Toolkit
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================

# --------------------------------------------
# Power Platform Authentication
# --------------------------------------------

# Microsoft Entra (Azure AD) Tenant ID
# Found in Azure Portal -> Microsoft Entra ID -> Properties -> Tenant ID
TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (Client) ID for the service principal
# Registered in Azure Portal -> App Registrations
CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client Secret for the service principal
# Generated in Azure Portal -> App Registrations -> Certificates & Secrets
CLIENT_SECRET=your-client-secret-here

# Target Power Platform Environment URL
# Found in Power Platform Admin Center -> Environments -> Environment URL
ENVIRONMENT_URL=https://your-org.crm.dynamics.com

# --------------------------------------------
# Dataverse Connection
# --------------------------------------------

# Dataverse environment URL (may differ from ENVIRONMENT_URL for dedicated instances)
DATAVERSE_URL=https://your-org.crm.dynamics.com

# Dataverse-specific client ID (if different from main CLIENT_ID)
DATAVERSE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Dataverse API version
DATAVERSE_API_VERSION=v9.2

# --------------------------------------------
# AI Builder / Copilot Studio
# --------------------------------------------

# AI Builder environment URL (if dedicated)
AI_BUILDER_ENVIRONMENT=https://your-org.crm.dynamics.com

# Azure OpenAI resource name (for custom AI integrations)
AZURE_OPENAI_RESOURCE=your-openai-resource-name

# Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-openai-api-key

# Azure OpenAI deployment name
AZURE_OPENAI_DEPLOYMENT=gpt-4

# --------------------------------------------
# Azure Subscription
# --------------------------------------------

# Azure Subscription ID
# Found in Azure Portal -> Subscriptions
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Azure Resource Group for shared resources
AZURE_RESOURCE_GROUP=power-platform-rg

# Azure Region for resource deployment
AZURE_REGION=eastus

# --------------------------------------------
# Azure DevOps
# --------------------------------------------

# Azure DevOps Organization URL
AZURE_DEVOPS_ORG=https://dev.azure.com/your-organization

# Azure DevOps Project Name
AZURE_DEVOPS_PROJECT=power-platform-projects

# Azure DevOps Personal Access Token (PAT)
# Generate at: Azure DevOps -> User Settings -> Personal Access Tokens
AZURE_DEVOPS_PAT=your-devops-pat-here

# --------------------------------------------
# GitHub
# --------------------------------------------

# GitHub Personal Access Token
# Generate at: GitHub -> Settings -> Developer Settings -> Personal Access Tokens
GITHUB_TOKEN=ghp_your-github-token-here

# GitHub Repository (for ALM and issue tracking)
GITHUB_REPO=your-org/power-platform-solutions

# GitHub API URL (for GitHub Enterprise, change this)
GITHUB_API_URL=https://api.github.com

# --------------------------------------------
# Service Accounts
# --------------------------------------------

# Service account email for automated operations
SERVICE_ACCOUNT_EMAIL=powerplatform-service@your-domain.com

# Service account password (use only in secure environments)
SERVICE_ACCOUNT_PASSWORD=your-service-account-password

# Service account object ID in Microsoft Entra ID
SERVICE_ACCOUNT_OBJECT_ID=00000000-0000-0000-0000-000000000000

# --------------------------------------------
# ALM / Deployment
# --------------------------------------------

# Source environment URL (development)
SOURCE_ENVIRONMENT_URL=https://dev-org.crm.dynamics.com

# Target environment URL (production)
TARGET_ENVIRONMENT_URL=https://prod-org.crm.dynamics.com

# Build environment URL (CI/CD)
BUILD_ENVIRONMENT_URL=https://build-org.crm.dynamics.com

# Solution publisher prefix (3-4 characters)
SOLUTION_PUBLISHER_PREFIX=abc

# Solution publisher name
SOLUTION_PUBLISHER_NAME=ABC Solutions

# --------------------------------------------
# Security
# --------------------------------------------

# Azure Key Vault name (for secret storage)
KEY_VAULT_NAME=your-keyvault-name

# Azure Key Vault URL
KEY_VAULT_URL=https://your-keyvault-name.vault.azure.net/

# DLP Policy name
DLP_POLICY_NAME=default-dlp-policy

# --------------------------------------------
# Monitoring
# --------------------------------------------

# Application Insights connection string (for telemetry)
APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://.../LiveEndpoint=https://...

# Log Analytics workspace ID
LOG_ANALYTICS_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# --------------------------------------------
# CLI Configuration
# --------------------------------------------

# Default output format for pp-agency CLI (json, table, markdown)
PP_AGENCY_OUTPUT_FORMAT=markdown

# Enable verbose logging (true/false)
PP_AGENCY_VERBOSE=false

# Default checklist type for `pp-agency checklist`
# One of: project-intake, scope-validation, deployment, qa, governance, support-handover
PP_AGENCY_DEFAULT_CHECKLIST=project-intake

# --------------------------------------------
# Development
# --------------------------------------------

# Node environment (development, production, test)
NODE_ENV=development

# Port for local documentation server
DOCS_PORT=3000

# Enable hot reload for development (true/false)
HOT_RELOAD=true
